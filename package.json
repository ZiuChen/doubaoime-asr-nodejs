{
  "name": "@ziuchen/doubaoime-asr",
  "type": "module",
  "version": "0.1.0",
  "description": "ASR SDK based on DoubaoIME for Node.js",
  "author": "ZiuChen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+git@github.com:ZiuChen/doubaoime-asr-nodejs.git"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "doubaoime-asr": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@discordjs/opus": "^0.10.0",
    "cac": "^6.7.14",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.18.0",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "esbuild"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
